// ============================================================================
//  [새로운 파일] 포스트 프로세싱 전용 셰이더 (postprocess.hlsl) 
// 화면 전체를 덮는 삼각형을 만들고, 거기에 필터를 씌우는 역할을 합니다.
// ============================================================================

// 1단계에서 100개의 큐브를 그렸던 '임시 도화지'를 텍스처(t0)로 받아옵니다!
Texture2D gOffscreenMap : register(t0);

// 텍스처를 읽어올 때 사용할 샘플러입니다.
SamplerState gsSamPointWrap : register(s0);

// 버텍스 셰이더에서 픽셀 셰이더로 넘겨줄 구조체입니다.
struct VSOutput
{
    float4 Pos : SV_POSITION; // 화면상에 그려질 2D 좌표입니다.
    float2 TexC : TEXCOORD; // 텍스처(임시 도화지)를 읽어올 UV 좌표입니다.
};

// ============================================================================
// [마법의 버텍스 셰이더]
// C++에서 버텍스 버퍼(정점 데이터)를 전혀 넘겨주지 않아도, 
// SV_VertexID(0, 1, 2)만을 이용해 화면 전체를 덮는 거대한 삼각형 1개를 창조해 냅니다!
// ============================================================================
VSOutput VSMain(uint vid : SV_VertexID)
{
    VSOutput output;
    
    // 비트 연산을 통해 ID(0, 1, 2)를 UV 좌표 (0,0), (2,0), (0,2)로 변환합니다.
    output.TexC = float2((vid << 1) & 2, vid & 2);
    
    // UV 좌표를 이용해 화면(-1 ~ 1)을 완전히 덮어버리는 거대한 삼각형의 위치를 계산합니다.
    output.Pos = float4(output.TexC * float2(2.0f, -2.0f) + float2(-1.0f, 1.0f), 0.0f, 1.0f);
    
    return output;
}

// ============================================================================
// [포스트 프로세스 픽셀 셰이더]
// 화면의 모든 픽셀마다 실행되며, 특수효과(필터)를 적용합니다.
// ============================================================================
float4 PSMain(VSOutput input) : SV_TARGET
{
    // 1. 임시 도화지(원본 화면)에서 현재 픽셀 위치의 색상을 그대로 가져옵니다.
    float4 color = gOffscreenMap.Sample(gsSamPointWrap, input.TexC);
    
    // 2. [특수 효과 1: 흑백 필터 (Grayscale)]
    // 사람의 눈이 가장 민감하게 반응하는 초록색(G) 비율을 높인 광도(Luminance) 공식으로 흑백을 만듭니다.
    float gray = dot(color.rgb, float3(0.299f, 0.587f, 0.114f));
    
    // 3. [특수 효과 2: 비네팅 (Vignette)]
    // 화면 테두리로 갈수록 점점 어두워지는 영화적인 효과를 만듭니다.
    float2 center = input.TexC - 0.5f; // 화면의 정중앙(0.5, 0.5)을 0,0으로 맞춥니다.
    float dist = length(center); // 중앙에서부터 현재 픽셀까지의 거리(반지름)를 구합니다.
    // 거리가 0.2부터 0.8 사이일 때 부드럽게 1.0에서 0.0으로 떨어지는 그라데이션 값을 만듭니다.
    float vignette = smoothstep(0.8f, 0.2f, dist);
    
    // 원본 색상 대신 흑백 색상을 넣고, 거기에 비네팅(어두워짐) 값을 곱해서 최종 모니터에 출력합니다!
    return float4(float3(gray, gray, gray) * vignette, 1.0f);
}
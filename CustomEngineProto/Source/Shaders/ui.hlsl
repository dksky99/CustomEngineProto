// ============================================================================
//  2D UI와 텍스처를 화면(픽셀 좌표)에 띄우는 전용 셰이더입니다! 
// ============================================================================

// 1. CPU에서 '루트 상수(Root Constants)'를 통해 쏘아줄 32비트 변수 6개입니다.
// 256바이트 정렬이 필요한 상수 버퍼(CBV)와 달리, 명령어에 직접 박혀서 날아오므로 엄청나게 빠릅니다!
cbuffer UIConstants : register(b0)
{
    float2 gPos; // UI 이미지가 그려질 모니터 화면의 좌상단 X, Y 픽셀 좌표입니다.
    float2 gSize; // UI 이미지의 가로, 세로 픽셀 크기(Width, Height)입니다.
    float2 gScreenSize; // 현재 모니터(윈도우 창)의 전체 가로, 세로 해상도입니다. (비율 계산용)
}; 

// 2. 화면에 띄울 UI 텍스처(예: 십자선, 체력바 이미지)를 받을 레지스터입니다.
Texture2D gTexture : register(t0);

// 3. UI 텍스처를 읽어올 때 사용할 부드러운 필터(Sampler)입니다.
SamplerState gsSamLinear : register(s0);

// 4. 버텍스 셰이더에서 픽셀 셰이더로 넘겨줄 데이터 포장 상자입니다.
struct VSOutput
{
    float4 Pos : SV_POSITION; // 최종 모니터 화면 좌표 (-1.0 ~ 1.0)
    float2 TexC : TEXCOORD; // 이미지의 UV 좌표 (0.0 ~ 1.0)
};

// ============================================================================
// [버텍스 셰이더] C++에서 정점 버퍼를 넘기지 않고, 여기서 6개의 점을 가상으로 만들어냅니다!
// ============================================================================
VSOutput VSMain(uint vid : SV_VertexID) // 시스템이 넘겨주는 정점 번호(0~5)를 받습니다.
{
    VSOutput output;
    
    // 사각형(Quad)을 만들기 위한 2개의 삼각형, 총 6개의 꼭짓점 UV 좌표를 셰이더 내부에 하드코딩해 둡니다.
    // 0번:(0,0) 좌상단, 1번:(1,0) 우상단, 2번:(0,1) 좌하단 ... (시계 방향 순서)
    float2 uvs[6] = { float2(0, 0), float2(1, 0), float2(0, 1), float2(0, 1), float2(1, 0), float2(1, 1) };
    
    // 현재 정점 번호에 맞는 UV 좌표를 하나 꺼내어 포장 상자에 담습니다.
    output.TexC = uvs[vid];
    
    // [픽셀 좌표 연산] 기준점(gPos)에서 시작하여, 크기(gSize)에 UV를 곱해 모니터 상의 실제 픽셀 좌표를 만듭니다.
    float2 pixelPos = gPos + output.TexC * gSize;
    
    // [NDC 좌표 변환] 모니터 픽셀 좌표(0~1280)를 DX12가 인식하는 화면 좌표계(-1.0 ~ 1.0)로 변환하는 공식입니다.
    // X축: 0을 -1.0으로, ScreenWidth를 1.0으로 변환합니다.
    float ndcX = (pixelPos.x / gScreenSize.x) * 2.0f - 1.0f;
    // Y축: 0을 1.0(위)으로, ScreenHeight를 -1.0(아래)으로 변환합니다. (Y축이 뒤집히므로 1.0에서 뺍니다)
    float ndcY = 1.0f - (pixelPos.y / gScreenSize.y) * 2.0f;
    
    // 2D UI이므로 Z값은 0.0f로 고정하고, 화면으로 넘겨줍니다.
    output.Pos = float4(ndcX, ndcY, 0.0f, 1.0f);
    
    return output;
}

// ============================================================================
// [픽셀 셰이더] 모니터에 UI의 색상을 칠합니다.
// ============================================================================
float4 PSMain(VSOutput input) : SV_TARGET
{
    // 텍스처 이미지에서 UV 좌표에 해당하는 색상을 부드럽게(Linear) 읽어옵니다.
    float4 color = gTexture.Sample(gsSamLinear, input.TexC);
    
    // 만약 읽어온 픽셀의 투명도(Alpha)가 0.05보다 작다면, 아예 그리지 않고 무시해버립니다(최적화).
    clip(color.a - 0.05f);
    
    // 최종적으로 읽어온 UI 색상(투명도 포함)을 도화지에 리턴합니다!
    return color;
}